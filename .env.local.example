# Gemini is called via Vertex AI using a service-account credential rather
# than a plain Gemini Developer API key (see README for why). Fill these in
# with your own project's values — none of this is a real secret by itself,
# but GOOGLE_APPLICATION_CREDENTIALS should point at a service-account JSON
# key file that you download yourself and keep out of git (gcp-service-account.json
# is already gitignored).
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/gcp-service-account.json
GEMINI_MODEL=gemini-2.5-flash

# Any long random string — used to sign session JWTs. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=change_this_to_a_long_random_string
